---
import '../styles/globals.css'
import Icon from './Icon.astro'
import { revealStaggerTokens } from '../utils/reveal'

interface Social {
  platform: string
  icon: string
  href: string
}

interface Member {
  name: string
  role: string
  bio?: string
  avatar: string
  socials?: Social[]
}

interface Props {
  member: Member
  index: number
}

const { member, index } = Astro.props
---

<div class:list={['ac-team__card', ...revealStaggerTokens(index)]}>
  <div class="ac-team__avatar-wrap">
    <img
      src={member.avatar}
      alt={member.name}
      class="ac-team__avatar"
      width="96"
      height="96"
      loading="lazy"
    />
  </div>

  <div class="ac-team__info">
    <h3 class="ac-team__name">{member.name}</h3>
    <p class="ac-team__role">{member.role}</p>
    {member.bio ? <p class="ac-team__bio">{member.bio}</p> : null}
  </div>

  {
    member.socials && member.socials.length > 0 && (
      <div class="ac-team__socials">
        {member.socials.map((social) => (
          <a
            href={social.href}
            class="ac-team__social-link"
            aria-label={social.platform}
            target="_blank"
            rel="noopener noreferrer"
          >
            <Icon name={social.icon} size={18} />
          </a>
        ))}
      </div>
    )
  }
</div>

<style>
  .ac-team__card {
    min-width: 0;
    background: var(--ac-card-bg);
    border: 0.0625rem solid var(--ac-border-color);
    border-radius: var(--ac-rounded-2xl);
    padding: var(--ac-spacing-8) var(--ac-spacing-6);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--ac-spacing-4);
    transition: var(--ac-transition);
    box-shadow: var(--ac-shadow-sm);
  }

  .ac-team__card:hover {
    transform: translateY(-0.25rem);
    box-shadow: var(--ac-shadow-lg);
    border-color: rgba(var(--ac-primary), 0.2);
  }

  .ac-team__avatar-wrap {
    position: relative;
  }

  .ac-team__avatar-wrap::after {
    content: '';
    position: absolute;
    inset: -0.1875rem;
    border-radius: 50%;
    background: var(--ac-gradient-primary);
    z-index: -1;
  }

  .ac-team__avatar {
    width: 6rem;
    height: 6rem;
    border-radius: 50%;
    object-fit: cover;
    border: 0.1875rem solid var(--ac-card-bg);
    display: block;
  }

  .ac-team__info {
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-1);
  }

  .ac-team__name {
    font-size: var(--ac-text-lg);
    font-weight: var(--ac-font-bold);
    color: var(--ac-text);
  }

  .ac-team__role {
    font-size: var(--ac-text-sm);
    font-weight: var(--ac-font-medium);
    color: rgb(var(--ac-primary));
  }

  .ac-team__bio {
    font-size: var(--ac-text-sm);
    color: var(--ac-text-muted);
    line-height: var(--ac-leading-relaxed);
    margin-top: var(--ac-spacing-2);
  }

  .ac-team__socials {
    display: flex;
    gap: var(--ac-spacing-3);
    margin-top: var(--ac-spacing-2);
  }

  .ac-team__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--ac-rounded-full);
    border: 0.0625rem solid var(--ac-border-color);
    color: var(--ac-text-muted);
    transition: var(--ac-transition);
    text-decoration: none;
  }

  .ac-team__social-link:hover {
    background: rgb(var(--ac-primary));
    border-color: rgb(var(--ac-primary));
    color: rgb(var(--ac-white));
    transform: translateY(-0.125rem);
  }
</style>

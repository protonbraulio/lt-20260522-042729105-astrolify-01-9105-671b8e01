---
import '../styles/globals.css'
import { siteConfig } from '../config/site.config'
import Badge from './Badge.astro'
import Icon from './Icon.astro'

const { hero } = siteConfig
const titleLines = hero.title.split('\n')
---

<section class="ac-hero">
  <div class="ac-hero__bg">
    <div class="ac-hero__gradient"></div>
    <div class="ac-hero__grid-pattern"></div>
  </div>

  <div class="container ac-hero__content">
    <div class="ac-hero__text">
      <div class="ac-hero__intro">
        {hero.badge && (
          <div class="animate-fade-in-up">
            <Badge label={hero.badge} variant="primary" size="medium" />
          </div>
        )}

        <h1 class="ac-hero__title animate-fade-in-up delay-100">
          {titleLines.map((line, i) => (
            <span>
              {i === titleLines.length - 1 ? (
                <span class="gradient-text">{line}</span>
              ) : (
                <>{line}<br /></>
              )}
            </span>
          ))}
        </h1>

        <p class="ac-hero__description animate-fade-in-up delay-200">
          {hero.description}
        </p>
      </div>

      <div class="ac-hero__after-intro">
        <div class="ac-hero__ctas animate-fade-in-up delay-300">
          <a href={hero.primaryCta.href} class="ac-hero__cta-primary">
            {hero.primaryCta.label}
            <Icon name="arrow_right" size={18} />
          </a>
          <a href={hero.secondaryCta.href} class="ac-hero__cta-secondary">
            {hero.secondaryCta.label}
          </a>
        </div>

        {hero.stats && (
          <div class="ac-hero__stats animate-fade-in-up delay-400">
            {hero.stats.map((stat) => (
              <div class="ac-hero__stat">
                <span class="ac-hero__stat-value">{stat.value}</span>
                <span class="ac-hero__stat-label">{stat.label}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .ac-hero {
    position: relative;
    overflow: hidden;
    padding: var(--ac-spacing-24) 0 var(--ac-spacing-32);
    min-height: 85vh;
    display: flex;
    align-items: center;
  }

  /* Background effects */
  .ac-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .ac-hero__gradient {
    position: absolute;
    top: -40%;
    left: 50%;
    transform: translateX(-50%);
    width: 50rem;
    height: 50rem;
    background: radial-gradient(
      circle,
      rgba(var(--ac-primary), 0.12) 0%,
      rgba(var(--ac-secondary), 0.08) 40%,
      transparent 70%
    );
    border-radius: 50%;
  }

  .ac-hero__grid-pattern {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(
        var(--ac-border-color) 0.0625rem,
        transparent 0.0625rem
      ),
      linear-gradient(90deg, var(--ac-border-color) 0.0625rem, transparent 0.0625rem);
    background-size: 3.75rem 3.75rem;
    opacity: 0.4;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
    -webkit-mask-image: radial-gradient(
      ellipse at center,
      black 30%,
      transparent 70%
    );
  }

  .ac-hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ac-hero__text {
    width: min(100%, 45rem);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ac-spacing-10);
  }

  .ac-hero__intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ac-spacing-6);
  }

  .ac-hero__after-intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ac-spacing-12);
    width: 100%;
  }

  .ac-hero__title {
    font-size: var(--ac-text-6xl);
    font-weight: var(--ac-font-extrabold);
    line-height: var(--ac-leading-tight);
    letter-spacing: -0.03em;
    color: var(--ac-text);
  }

  .ac-hero__description {
    font-size: var(--ac-text-xl);
    color: var(--ac-text-muted);
    line-height: var(--ac-leading-relaxed);
    max-width: 35rem;
  }

  .ac-hero__ctas {
    display: flex;
    gap: var(--ac-spacing-4);
  }

  .ac-hero__cta-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--ac-spacing-2);
    padding: var(--ac-spacing-3-5) var(--ac-spacing-7);
    font-size: var(--ac-text-md);
    font-weight: var(--ac-font-semibold);
    color: rgb(var(--ac-white));
    background: var(--ac-gradient-primary);
    border-radius: var(--ac-rounded-xl);
    text-decoration: none;
    transition: var(--ac-transition);
  }

  .ac-hero__cta-primary:hover {
    opacity: 0.9;
    transform: translateY(-0.125rem);
    box-shadow: 0 0.5rem 1.5rem rgba(var(--ac-primary), 0.4);
  }

  .ac-hero__cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: var(--ac-spacing-3-5) var(--ac-spacing-7);
    font-size: var(--ac-text-md);
    font-weight: var(--ac-font-semibold);
    color: var(--ac-text);
    background-color: transparent;
    border: 0.125rem solid var(--ac-border-color);
    border-radius: var(--ac-rounded-xl);
    text-decoration: none;
    transition: var(--ac-transition);
  }

  .ac-hero__cta-secondary:hover {
    border-color: rgb(var(--ac-primary));
    color: rgb(var(--ac-primary));
    transform: translateY(-0.125rem);
  }

  /* Stats */
  .ac-hero__stats {
    display: flex;
    gap: var(--ac-spacing-12);
    padding-top: var(--ac-spacing-8);
    border-top: 0.0625rem solid var(--ac-border-color);
    width: 100%;
    justify-content: center;
  }

  .ac-hero__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ac-spacing-1);
  }

  .ac-hero__stat-value {
    font-size: var(--ac-text-3xl);
    font-weight: var(--ac-font-bold);
    color: var(--ac-text);
  }

  .ac-hero__stat-label {
    font-size: var(--ac-text-sm);
    color: var(--ac-text-muted);
  }

  @media (max-width: 48rem) {
    .ac-hero {
      padding: var(--ac-spacing-16) 0 var(--ac-spacing-20);
      min-height: auto;
    }

    .ac-hero__title {
      font-size: var(--ac-text-4xl);
    }

    .ac-hero__description {
      font-size: var(--ac-text-lg);
    }

    .ac-hero__ctas {
      flex-direction: column;
      width: 100%;
    }

    .ac-hero__cta-primary,
    .ac-hero__cta-secondary {
      justify-content: center;
    }

    .ac-hero__stats {
      gap: var(--ac-spacing-8);
    }

    .ac-hero__stat-value {
      font-size: var(--ac-text-2xl);
    }
  }
</style>

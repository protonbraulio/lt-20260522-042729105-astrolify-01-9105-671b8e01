---
import '../styles/globals.css'
import { siteConfig } from '../config/site.config'
import LandingSection from './LandingSection.astro'
import SectionHeader from './SectionHeader.astro'
import TeamMemberCard from './TeamMemberCard.astro'

const { team } = siteConfig
---

<LandingSection id="team" class="section ac-section-band--subtle">
  <div class="ac-team">
    <SectionHeader
      badge={team.badge}
      title={team.title}
      description={team.description}
      badgeSize="medium"
    />

    <div class="ac-team__grid">
      {team.members.map((member, i) => <TeamMemberCard member={member} index={i} />)}
    </div>
  </div>
</LandingSection>

<style>
  .ac-team {
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-16);
  }

  .ac-team__grid {
    display: grid;
    grid-template-columns: 1fr;
    column-gap: var(--ac-spacing-6);
    row-gap: var(--ac-spacing-8);
  }

  @media (min-width: 40rem) {
    .ac-team__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .ac-team__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>

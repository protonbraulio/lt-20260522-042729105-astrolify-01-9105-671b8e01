---
import '../styles/globals.css'

interface Props {
  autoplay?: boolean
  interval?: number
  class?: string
}

const {
  autoplay = false,
  interval = 5000,
  class: className,
} = Astro.props
---

<div
  class:list={['ac-slider', className]}
  data-slider
  data-autoplay={autoplay}
  data-interval={interval}
>
  <div class="ac-slider__track">
    <slot />
  </div>

  <div class="ac-slider__controls">
    <button class="ac-slider__btn ac-slider__btn--prev" data-slider-prev aria-label="Previous slide">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <div class="ac-slider__dots" data-slider-dots></div>

    <button class="ac-slider__btn ac-slider__btn--next" data-slider-next aria-label="Next slide">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</div>

<style>
  .ac-slider {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-8);
  }

  /* CSS scroll snap — no JS needed for the actual sliding */
  .ac-slider__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none; /* Firefox */
  }

  .ac-slider__track::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  .ac-slider__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--ac-spacing-4);
  }

  .ac-slider__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--ac-rounded-full);
    border: 0.0625rem solid var(--ac-border-color);
    background-color: var(--ac-card-bg);
    color: var(--ac-text);
    cursor: pointer;
    transition: var(--ac-transition);
  }

  .ac-slider__btn:hover {
    background-color: rgb(var(--ac-primary));
    border-color: rgb(var(--ac-primary));
    color: rgb(var(--ac-white));
  }

  .ac-slider__dots {
    display: flex;
    gap: var(--ac-spacing-2);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-slider]').forEach((slider) => {
    const track = slider.querySelector<HTMLElement>('.ac-slider__track')
    const prevBtn = slider.querySelector('[data-slider-prev]')
    const nextBtn = slider.querySelector('[data-slider-next]')
    const dotsContainer = slider.querySelector('[data-slider-dots]')
    const autoplay = slider.dataset.autoplay === 'true'
    const interval = Number(slider.dataset.interval) || 5000

    if (!track || !dotsContainer) return

    const slides = Array.from(track.children) as HTMLElement[]
    let current = 0
    let timer: ReturnType<typeof setInterval> | null = null

    // Create dots
    slides.forEach((_, i) => {
      const dot = document.createElement('button')
      dot.classList.add('ac-slider__dot')
      if (i === 0) dot.classList.add('ac-slider__dot--active')
      dot.setAttribute('aria-label', `Go to slide ${i + 1}`)
      dot.addEventListener('click', () => scrollTo(i))
      dotsContainer.appendChild(dot)
    })

    const dots = dotsContainer.querySelectorAll('.ac-slider__dot')

    function scrollTo(index: number) {
      current = ((index % slides.length) + slides.length) % slides.length
      track!.scrollLeft = slides[current].offsetLeft
      updateDots()
      resetAutoplay()
    }

    function updateDots() {
      dots.forEach((d, i) => d.classList.toggle('ac-slider__dot--active', i === current))
    }

    function resetAutoplay() {
      if (timer) clearInterval(timer)
      if (autoplay) timer = setInterval(() => scrollTo(current + 1), interval)
    }

    prevBtn?.addEventListener('click', () => scrollTo(current - 1))
    nextBtn?.addEventListener('click', () => scrollTo(current + 1))

    // Sync dot state when user swipes natively
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            current = slides.indexOf(entry.target as HTMLElement)
            updateDots()
          }
        }
      },
      { root: track, threshold: 0.5 }
    )

    slides.forEach((slide) => observer.observe(slide))

    resetAutoplay()
  })
</script>

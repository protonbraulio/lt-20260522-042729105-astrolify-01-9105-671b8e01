---
import '../styles/globals.css'
import { siteConfig } from '../config/site.config'
import LandingSection from './LandingSection.astro'
import SectionHeader from './SectionHeader.astro'
import Icon from './Icon.astro'

const { comparison } = siteConfig
---

<LandingSection class="section" id="comparison">
  <div class="ac-comparison">
    <SectionHeader
      badge={comparison.badge}
      title={comparison.title}
      description={comparison.description}
      badgeSize="medium"
    />

    <div class="ac-comparison__table-wrapper animate-fade-in-up">
      <table class="ac-comparison__table">
        <thead>
          <tr>
            <th class="ac-comparison__th ac-comparison__th--feature">Feature</th>
            {comparison.columns.map((col) => (
              <th class:list={['ac-comparison__th', col.highlighted && 'ac-comparison__th--highlighted']}>
                <div class="ac-comparison__col-header">
                  {col.highlighted && <span class="ac-comparison__col-badge">Most Popular</span>}
                  <span class="ac-comparison__col-name">{col.name}</span>
                  {col.price && <span class="ac-comparison__col-price">{col.price}</span>}
                </div>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {comparison.rows.map((row) => (
            <tr class="ac-comparison__row">
              <td class="ac-comparison__td ac-comparison__td--feature">
                <span class="ac-comparison__feature-name">{row.feature}</span>
                {row.tooltip && <span class="ac-comparison__tooltip" title={row.tooltip}>
                  <Icon name="info" size={14} />
                </span>}
              </td>
              {row.values.map((val, i) => (
                <td class:list={['ac-comparison__td', comparison.columns[i]?.highlighted && 'ac-comparison__td--highlighted']}>
                  {typeof val === 'boolean' ? (
                    val ? (
                      <span class="ac-comparison__check">
                        <Icon name="check" size={18} />
                      </span>
                    ) : (
                      <span class="ac-comparison__x">
                        <Icon name="clear" size={18} />
                      </span>
                    )
                  ) : (
                    <span class="ac-comparison__value">{val}</span>
                  )}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
        <tfoot>
          <tr>
            <td class="ac-comparison__td ac-comparison__td--feature"></td>
            {comparison.columns.map((col) => (
              <td class:list={['ac-comparison__td ac-comparison__tfoot-cta', col.highlighted && 'ac-comparison__td--highlighted']}>
                <a href={col.cta.href} class:list={['ac-comparison__cta-btn', col.highlighted && 'ac-comparison__cta-btn--primary']}>
                  {col.cta.label}
                </a>
              </td>
            ))}
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
</LandingSection>

<style>
  /* Misma separación que `.section .container > *` cuando el bloque era hijo directo del container. */
  .ac-comparison {
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-16);
  }

  .ac-comparison__table-wrapper {
    overflow-x: auto;
    border-radius: var(--ac-rounded-2xl);
    border: 0.0625rem solid var(--ac-border-color);
    box-shadow: var(--ac-shadow-lg);
  }

  .ac-comparison__table {
    width: 100%;
    border-collapse: collapse;
    min-width: 37.5rem;
  }

  /* Header */
  .ac-comparison__th {
    padding: var(--ac-spacing-8) var(--ac-spacing-6);
    background: var(--ac-bg-subtle);
    border-bottom: 0.0625rem solid var(--ac-border-color);
    text-align: center;
    vertical-align: bottom;
  }

  .ac-comparison__th--feature {
    text-align: left;
    width: 35%;
  }

  .ac-comparison__th--highlighted {
    background: rgba(var(--ac-primary), 0.06);
    border-top: 0.1875rem solid rgb(var(--ac-primary));
  }

  .ac-comparison__col-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ac-spacing-2);
  }

  .ac-comparison__col-badge {
    font-size: var(--ac-text-xs);
    font-weight: var(--ac-font-semibold);
    color: rgb(var(--ac-primary));
    background: rgba(var(--ac-primary), 0.1);
    padding: var(--ac-spacing-1) var(--ac-spacing-3);
    border-radius: var(--ac-rounded-full);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ac-comparison__col-name {
    font-size: var(--ac-text-lg);
    font-weight: var(--ac-font-bold);
    color: var(--ac-text);
  }

  .ac-comparison__col-price {
    font-size: var(--ac-text-sm);
    color: var(--ac-text-muted);
  }

  /* Rows */
  .ac-comparison__row {
    border-bottom: 0.0625rem solid var(--ac-border-color);
    transition: background 0.15s ease;
  }

  .ac-comparison__row:last-child {
    border-bottom: none;
  }

  .ac-comparison__row:hover {
    background: var(--ac-bg-subtle);
  }

  .ac-comparison__td {
    padding: var(--ac-spacing-6) var(--ac-spacing-6);
    text-align: center;
    vertical-align: middle;
  }

  .ac-comparison__td--feature {
    text-align: left;
  }

  .ac-comparison__td--highlighted {
    background: rgba(var(--ac-primary), 0.03);
  }

  .ac-comparison__feature-name {
    font-size: var(--ac-text-sm);
    color: var(--ac-text);
    font-weight: var(--ac-font-medium);
  }

  .ac-comparison__tooltip {
    display: inline-flex;
    margin-left: var(--ac-spacing-1);
    color: var(--ac-text-muted);
    cursor: help;
    vertical-align: middle;
  }

  .ac-comparison__check {
    display: inline-flex;
    color: rgb(var(--ac-primary));
  }

  .ac-comparison__x {
    display: inline-flex;
    color: var(--ac-text-muted);
    opacity: 0.4;
  }

  .ac-comparison__value {
    font-size: var(--ac-text-sm);
    color: var(--ac-text);
    font-weight: var(--ac-font-medium);
  }

  /* Footer CTA */
  .ac-comparison__tfoot-cta {
    padding: var(--ac-spacing-8) var(--ac-spacing-6);
    border-top: 0.0625rem solid var(--ac-border-color);
  }

  .ac-comparison__cta-btn {
    display: inline-block;
    width: 100%;
    text-align: center;
    padding: var(--ac-spacing-3) var(--ac-spacing-6);
    font-size: var(--ac-text-sm);
    font-weight: var(--ac-font-semibold);
    border-radius: var(--ac-rounded-xl);
    border: 0.125rem solid var(--ac-border-color);
    color: var(--ac-text);
    text-decoration: none;
    transition: var(--ac-transition);
  }

  .ac-comparison__cta-btn:hover {
    border-color: rgb(var(--ac-primary));
    color: rgb(var(--ac-primary));
  }

  .ac-comparison__cta-btn--primary {
    background: var(--ac-gradient-primary);
    border-color: transparent;
    color: rgb(var(--ac-white));
  }

  .ac-comparison__cta-btn--primary:hover {
    opacity: 0.9;
    border-color: transparent;
    color: rgb(var(--ac-white));
    transform: translateY(-0.0625rem);
    box-shadow: 0 0.25rem 1rem rgba(var(--ac-primary), 0.35);
  }
</style>

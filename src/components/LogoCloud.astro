---
import '../styles/globals.css'
import { siteConfig } from '../config/site.config'
import { logoCloudSvgPaths } from '../data/logocloud-logo-paths'
import LandingSection from './LandingSection.astro'

const { logocloud } = siteConfig
---

<LandingSection class="section ac-section-dividers-y" containerClass="animate-fade-in-up">
  <div class="ac-logocloud">
    <p class="ac-logocloud__label">{logocloud.title}</p>

    <div class="ac-logocloud__row">
      {logocloud.logos.map((logo) => (
        <div class="ac-logocloud__item" title={logo.name}>
          {logoCloudSvgPaths[logo.id] ? (
            <svg
              class="ac-logocloud__icon"
              viewBox={logoCloudSvgPaths[logo.id]!.viewBox ?? '0 0 24 24'}
              xmlns="http://www.w3.org/2000/svg"
              fill="currentColor"
              aria-label={logo.name}
              set:html={logoCloudSvgPaths[logo.id]!.path}
            ></svg>
          ) : (
            <span class="ac-logocloud__text">{logo.name}</span>
          )}
        </div>
      ))}
    </div>
  </div>
</LandingSection>

<style>
  .ac-logocloud {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ac-spacing-10);
  }

  .ac-logocloud__label {
    font-size: var(--ac-text-xs);
    font-weight: var(--ac-font-semibold);
    color: var(--ac-text-muted);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .ac-logocloud__row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--ac-spacing-4) var(--ac-spacing-12);
  }

  .ac-logocloud__item {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    opacity: 0.5;
    transition: opacity 0.25s ease, transform 0.25s ease;
    color: var(--ac-text);
  }

  .ac-logocloud__item:hover {
    opacity: 0.85;
    transform: translateY(-0.125rem);
  }

  .ac-logocloud__icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ac-logocloud__text {
    font-size: var(--ac-text-lg);
    font-weight: var(--ac-font-bold);
    color: var(--ac-text);
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  @media (max-width: 40rem) {
    .ac-logocloud__row {
      gap: var(--ac-spacing-4) var(--ac-spacing-8);
    }

    .ac-logocloud__item {
      width: 2.5rem;
      height: 2.5rem;
    }
  }
</style>

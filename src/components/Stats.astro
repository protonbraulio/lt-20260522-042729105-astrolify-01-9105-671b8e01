---
import '../styles/globals.css'
import { siteConfig } from '../config/site.config'
import { revealStaggerTokens } from '../utils/reveal'

const { stats } = siteConfig
---

<section class="ac-stats">
  <!-- Background decorations -->
  <div class="ac-stats__bg" aria-hidden="true">
    <div class="ac-stats__blob ac-stats__blob--1"></div>
    <div class="ac-stats__blob ac-stats__blob--2"></div>
  </div>

  <div class="container ac-stats__inner">
    {stats.items.map((stat, i) => (
      <>
        <div class:list={['ac-stats__item', ...revealStaggerTokens(i)]}>
          <div class="ac-stats__value">{stat.value}</div>
          <div class="ac-stats__label">{stat.label}</div>
        </div>
        {i < stats.items.length - 1 && (
          <div class="ac-stats__divider" aria-hidden="true"></div>
        )}
      </>
    ))}
  </div>
</section>

<style>
  .ac-stats {
    padding: var(--ac-spacing-20) 0;
    background: var(--ac-gradient-primary);
    position: relative;
    overflow: hidden;
  }

  /* Decorative blobs */
  .ac-stats__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .ac-stats__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(5rem);
  }

  .ac-stats__blob--1 {
    width: 31.25rem;
    height: 31.25rem;
    background: rgba(255, 255, 255, 0.08);
    top: -12.5rem;
    right: -6.25rem;
  }

  .ac-stats__blob--2 {
    width: 25rem;
    height: 25rem;
    background: rgba(255, 255, 255, 0.05);
    bottom: -9.375rem;
    left: -5rem;
  }

  .ac-stats__inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
  }

  .ac-stats__item {
    flex: 1;
    min-width: 10rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ac-spacing-2);
    padding: var(--ac-spacing-8) var(--ac-spacing-6);
    text-align: center;
  }

  .ac-stats__divider {
    width: 0.0625rem;
    height: 3.75rem;
    background: rgba(255, 255, 255, 0.2);
    flex-shrink: 0;
  }

  .ac-stats__value {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: var(--ac-font-extrabold);
    color: rgb(var(--ac-white));
    line-height: var(--ac-leading-none);
    letter-spacing: -0.02em;
  }

  .ac-stats__label {
    font-size: var(--ac-text-sm);
    color: rgba(var(--ac-white), 0.75);
    font-weight: var(--ac-font-medium);
    letter-spacing: 0.02em;
  }

  @media (max-width: 48rem) {
    .ac-stats {
      padding: var(--ac-spacing-14) 0;
    }

    .ac-stats__inner {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0;
    }

    .ac-stats__divider {
      display: none;
    }

    .ac-stats__item {
      border-right: 0.0625rem solid rgba(255, 255, 255, 0.15);
      border-bottom: 0.0625rem solid rgba(255, 255, 255, 0.15);
    }

    .ac-stats__item:nth-child(even) {
      border-right: none;
    }

    .ac-stats__item:nth-last-child(-n+2) {
      border-bottom: none;
    }
  }
</style>

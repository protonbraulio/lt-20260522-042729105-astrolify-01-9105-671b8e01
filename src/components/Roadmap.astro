---
import '../styles/globals.css'
import { siteConfig } from '../config/site.config'
import LandingSection from './LandingSection.astro'
import SectionHeader from './SectionHeader.astro'
import Icon from './Icon.astro'
import { revealStaggerTokens } from '../utils/reveal'

const { roadmap } = siteConfig

const statusColors: Record<string, string> = {
  done: 'var(--ac-color-success, #22c55e)',
  'in-progress': 'rgb(var(--ac-primary))',
  planned: 'var(--ac-text-muted)',
}

const statusLabels: Record<string, string> = {
  done: 'Released',
  'in-progress': 'In Progress',
  planned: 'Planned',
}
---

<LandingSection class="section" id="roadmap">
  <div class="ac-roadmap">
    <SectionHeader
      badge={roadmap.badge}
      title={roadmap.title}
      description={roadmap.description}
      badgeSize="medium"
    />

    <div class="ac-roadmap__timeline">
      {roadmap.items.map((item, index) => (
        <div
          class:list={[
            'ac-roadmap__item',
            `ac-roadmap__item--${item.status}`,
            ...revealStaggerTokens(index),
          ]}
        >
          <!-- Left: Date -->
          <div class="ac-roadmap__date">
            <span class="ac-roadmap__period">{item.period}</span>
          </div>

          <!-- Center: Line + Dot -->
          <div class="ac-roadmap__spine">
            <div class="ac-roadmap__dot">
              {item.status === 'done' && <Icon name="check" size={14} />}
              {item.status === 'in-progress' && <span class="ac-roadmap__pulse" />}
            </div>
            {index < roadmap.items.length - 1 && <div class="ac-roadmap__line" />}
          </div>

          <!-- Right: Content -->
          <div class="ac-roadmap__content">
            <div class="ac-roadmap__status-pill" style={`color: ${statusColors[item.status] ?? 'currentcolor'}`}>
              <span class="ac-roadmap__status-dot" style={`background: ${statusColors[item.status] ?? 'currentcolor'}`} />
              {statusLabels[item.status] ?? item.status}
            </div>
            <h3 class="ac-roadmap__title">{item.title}</h3>
            <p class="ac-roadmap__description">{item.description}</p>
            {item.tags && (
              <div class="ac-roadmap__tags">
                {item.tags.map((tag) => (
                  <span class="ac-roadmap__tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</LandingSection>

<style>
  .ac-roadmap {
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-16);
    min-width: 0;
  }

  .ac-roadmap__timeline {
    max-width: 47.5rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-12);
    min-width: 0;
  }

  .ac-roadmap__item {
    display: grid;
    grid-template-columns: 7.5rem 2.5rem minmax(0, 1fr);
    gap: 0 var(--ac-spacing-6);
    min-height: 6.25rem;
    min-width: 0;
  }

  /* Date */
  .ac-roadmap__date {
    text-align: right;
    padding-top: var(--ac-spacing-1);
  }

  .ac-roadmap__period {
    font-size: var(--ac-text-sm);
    font-weight: var(--ac-font-semibold);
    color: var(--ac-text-muted);
    white-space: nowrap;
  }

  /* Spine */
  .ac-roadmap__spine {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .ac-roadmap__dot {
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: var(--ac-card-bg);
    border: 0.125rem solid var(--ac-border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    position: relative;
  }

  .ac-roadmap__item--done .ac-roadmap__dot {
    background: var(--ac-gradient-primary);
    border-color: transparent;
    color: rgb(var(--ac-white));
  }

  .ac-roadmap__item--in-progress .ac-roadmap__dot {
    border-color: rgb(var(--ac-primary));
    background: rgba(var(--ac-primary), 0.1);
    color: rgb(var(--ac-primary));
  }

  .ac-roadmap__pulse {
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 50%;
    background: rgb(var(--ac-primary));
    display: block;
    animation: pulse 1.8s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.5); opacity: 0.6; }
  }

  .ac-roadmap__line {
    flex: 1;
    width: 0.125rem;
    background: var(--ac-border-color);
    margin: var(--ac-spacing-2) 0;
  }

  .ac-roadmap__item--done .ac-roadmap__line {
    background: var(--ac-gradient-primary);
  }

  /* Content */
  .ac-roadmap__content {
    padding-bottom: 0;
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-3);
    min-width: 0;
  }

  .ac-roadmap__status-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--ac-spacing-2);
    font-size: var(--ac-text-xs);
    font-weight: var(--ac-font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .ac-roadmap__status-dot {
    width: 0.4375rem;
    height: 0.4375rem;
    border-radius: 50%;
    display: inline-block;
    flex-shrink: 0;
  }

  .ac-roadmap__title {
    font-size: var(--ac-text-xl);
    font-weight: var(--ac-font-bold);
    color: var(--ac-text);
  }

  .ac-roadmap__item--planned .ac-roadmap__title {
    color: var(--ac-text-muted);
  }

  .ac-roadmap__description {
    font-size: var(--ac-text-sm);
    color: var(--ac-text-muted);
    line-height: var(--ac-leading-relaxed);
  }

  .ac-roadmap__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--ac-spacing-2);
    margin-top: var(--ac-spacing-2);
  }

  .ac-roadmap__tag {
    font-size: var(--ac-text-xs);
    font-weight: var(--ac-font-medium);
    padding: 0.125rem var(--ac-spacing-3);
    border-radius: var(--ac-rounded-full);
    background: rgba(var(--ac-primary), 0.1);
    color: rgb(var(--ac-primary));
    border: 0.0625rem solid rgba(var(--ac-primary), 0.2);
  }

  @media (max-width: 40rem) {
    .ac-roadmap__item {
      grid-template-columns: 5rem 2rem minmax(0, 1fr);
      gap: 0 var(--ac-spacing-3);
    }

    .ac-roadmap__period {
      font-size: var(--ac-text-xs);
    }

    .ac-roadmap__dot {
      width: 1.75rem;
      height: 1.75rem;
    }
  }
</style>

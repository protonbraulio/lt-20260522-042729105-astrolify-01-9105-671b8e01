---
import '../styles/globals.css'
import { siteConfig } from '../config/site.config'
import LandingSection from './LandingSection.astro'
import SectionHeader from './SectionHeader.astro'
import PricingBillingToggle from './PricingBillingToggle.astro'
import PricingCard from './PricingCard.astro'

const { pricing } = siteConfig
---

<LandingSection id="pricing" class="section ac-section-band--subtle">
  <SectionHeader badge={pricing.badge} title={pricing.title} description={pricing.description}>
    <PricingBillingToggle />
  </SectionHeader>

  <div class="ac-pricing__grid">
    {pricing.plans.map((plan, i) => <PricingCard plan={plan} index={i} />)}
  </div>
</LandingSection>

<style>
  .ac-pricing__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--ac-spacing-6);
    align-items: start;
  }

  @media (max-width: 48rem) {
    .ac-pricing__grid {
      grid-template-columns: 1fr;
      max-width: 25rem;
      align-self: center;
    }
  }

  @media (min-width: 48.0625rem) and (max-width: 64rem) {
    .ac-pricing__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLInputElement>('[data-pricing-toggle]')
  const amounts = document.querySelectorAll('.ac-pricing__amount')
  const labels = document.querySelectorAll('[data-toggle-label]')

  const applyBilling = (isYearly: boolean) => {
    amounts.forEach((el) => {
      const monthly = el.getAttribute('data-monthly')
      const yearly = el.getAttribute('data-yearly')
      el.textContent = isYearly ? yearly : monthly
    })

    labels.forEach((label) => {
      const isMonthly = label.getAttribute('data-toggle-label') === 'monthly'
      label.classList.toggle(
        'ac-pricing__toggle-label--active',
        isYearly ? !isMonthly : isMonthly
      )
    })
  }

  toggle?.addEventListener('change', () => {
    applyBilling(toggle.checked)
  })
</script>

---
import Icon from './Icon.astro'

interface Props {
  open?: boolean
  title: string
  name?: string
  class?: string
  /** `plus`: icono + con rotación. `chevron`: chevron en círculo (p. ej. FAQ). */
  toggleStyle?: 'plus' | 'chevron'
}

const {
  open,
  title,
  name,
  class: className,
  toggleStyle = 'plus',
} = Astro.props
---

<details
  data-accordion-item
  class:list={['ac-accordion-item', className]}
  data-accordion-toggle={toggleStyle}
  name={name}
  open={open}
>
  <summary class="ac-accordion-item-title">
    <span>{title}</span>
    {
      toggleStyle === 'chevron' ? (
        <span class="ac-accordion-item-chevron">
          <Icon name="chevron_down" size={20} class="ac-icon--accordion-chevron" />
        </span>
      ) : (
        <Icon icon="add" />
      )
    }
  </summary>
  <div class="ac-accordion-item-content">
    <div class="ac-accordion-slot">
      <slot />
    </div>
  </div>
</details>

<style>
  .ac-accordion-item {
    margin: 0;
    font-family: var(--ac-font-sans);
    height: var(--ac-accordion-item-collapsed);
    overflow: hidden;
    background-color: var(--ac-card-bg);
    border: 0.0625rem solid var(--ac-card-border);
    border-radius: var(--ac-rounded-xl);
    box-shadow: var(--ac-shadow-sm);
    padding: 0;
    transition:
      border-color var(--ac-transition),
      box-shadow var(--ac-transition);

    &:hover {
      border-color: rgba(var(--ac-primary), 0.3);
    }

    &[open] {
      height: var(--ac-accordion-item-expanded);
      border-color: rgba(var(--ac-primary), 0.3);
      box-shadow: 0 0 0 0.1875rem rgba(var(--ac-primary), 0.05);

      .ac-accordion-item-title {
        color: var(--ac-text);
      }

      &[data-accordion-toggle='plus'] .ac-accordion-item-title > :global(.ac-icon) {
        transform: rotate(-45deg);
      }

      &[data-accordion-toggle='chevron'] .ac-accordion-item-chevron {
        background: var(--ac-gradient-primary);
        color: rgb(var(--ac-white));
      }

      &[data-accordion-toggle='chevron']
        .ac-accordion-item-chevron
        :global(.ac-icon.ac-icon--accordion-chevron) {
        transform: rotate(180deg);
      }
    }

    &.accordion-item--animated {
      transition: height 0.3s linear;
    }
  }

  .ac-accordion-item-title {
    align-items: center;
    color: var(--ac-text);
    cursor: pointer;
    display: flex;
    font-size: var(--ac-text-md);
    font-weight: var(--ac-font-semibold);
    gap: var(--ac-spacing-3);
    justify-content: space-between;
    line-height: var(--ac-leading-normal);
    list-style-type: none;
    padding: var(--ac-spacing-5) var(--ac-spacing-6);
    transition: color 0.3s ease-in-out;

    &:hover,
    &:focus {
      color: var(--ac-text);
    }

    &::marker,
    &::-webkit-details-marker {
      display: none;
    }

    & > span:first-child {
      flex: 1 1 auto;
      min-width: 0;
    }

    & > :global(.ac-icon) {
      width: var(--ac-spacing-6);
      height: var(--ac-spacing-6);
      transition: transform 0.3s ease-in-out;
      color: rgb(var(--ac-color-400));
    }
  }

  .ac-accordion-item-chevron {
    align-items: center;
    aspect-ratio: 1;
    border-radius: 50%;
    box-sizing: border-box;
    display: inline-flex;
    flex: 0 0 auto;
    height: 2rem;
    justify-content: center;
    width: 2rem;
    background-color: var(--ac-bg-muted);
    color: var(--ac-text-muted);
    transition:
      background-color 0.3s ease-in-out,
      color 0.3s ease-in-out;

    :global(.ac-icon.ac-icon--accordion-chevron) {
      transition: transform 0.3s ease-in-out;
    }
  }

  .ac-accordion-item-content {
    padding: 0;
  }

  /* Slotted FAQ answers: keep one targeted :global for projected nodes from the parent page. */
  .ac-accordion-slot > :global(*) {
    margin: 0;
    color: var(--ac-text-muted);
    font-size: var(--ac-text-sm);
    line-height: var(--ac-leading-relaxed);
    padding-left: var(--ac-spacing-6);
    padding-right: var(--ac-spacing-6);
  }

  .ac-accordion-slot > :global(*:last-child) {
    padding-bottom: var(--ac-spacing-6);
  }

  @media (max-width: 48rem) {
    .ac-accordion-item-title {
      font-size: var(--ac-text-sm);
      padding: var(--ac-spacing-4) var(--ac-spacing-5);
    }

    .ac-accordion-slot > :global(*) {
      padding-left: var(--ac-spacing-5);
      padding-right: var(--ac-spacing-5);
    }

    .ac-accordion-slot > :global(*:last-child) {
      padding-bottom: var(--ac-spacing-5);
    }
  }
</style>

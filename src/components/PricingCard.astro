---
import '../styles/globals.css'
import Badge from './Badge.astro'
import PricingFeatureList from './PricingFeatureList.astro'
import { revealStaggerTokens } from '../utils/reveal'

export interface PricingPlan {
  name: string
  description: string
  monthlyPrice: number
  yearlyPrice: number
  featured?: boolean
  features: string[]
  cta: { label: string; href: string }
}

interface Props {
  plan: PricingPlan
  index: number
}

const { plan, index } = Astro.props
---

<div
  class:list={[
    'ac-pricing__card',
    plan.featured && 'ac-pricing__card--featured',
    ...revealStaggerTokens(index),
  ]}
>
  {
    plan.featured && (
      <div class="ac-pricing__popular">
        <Badge label="Most Popular" variant="gradient" size="small" />
      </div>
    )
  }

  <div class="ac-pricing__header">
    <h3 class="ac-pricing__name">{plan.name}</h3>
    <p class="ac-pricing__description">{plan.description}</p>
  </div>

  <div class="ac-pricing__price">
    <span class="ac-pricing__currency">$</span>
    <span
      class="ac-pricing__amount"
      data-monthly={plan.monthlyPrice}
      data-yearly={plan.yearlyPrice}
    >
      {plan.monthlyPrice}
    </span>
    <span class="ac-pricing__period">/month</span>
  </div>

  <div class="ac-pricing__lower">
    <a
      href={plan.cta.href}
      class:list={['ac-pricing__cta', plan.featured && 'ac-pricing__cta--featured']}
    >
      {plan.cta.label}
    </a>
    <PricingFeatureList items={plan.features} />
  </div>
</div>

<style>
  .ac-pricing__card {
    background-color: var(--ac-card-bg);
    border: 0.0625rem solid var(--ac-card-border);
    border-radius: var(--ac-rounded-2xl);
    padding: var(--ac-spacing-8);
    position: relative;
    transition: var(--ac-transition);
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-6);
  }

  .ac-pricing__card:hover {
    transform: translateY(-0.25rem);
    box-shadow: var(--ac-shadow-xl);
  }

  .ac-pricing__card--featured {
    border: 0.125rem solid rgb(var(--ac-primary));
    box-shadow: 0 0 0 0.25rem rgba(var(--ac-primary), 0.1);
    transform: scale(1.02);
  }

  .ac-pricing__card--featured:hover {
    transform: scale(1.02) translateY(-0.25rem);
  }

  .ac-pricing__popular {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
  }

  .ac-pricing__header {
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-1);
  }

  .ac-pricing__name {
    font-size: var(--ac-text-xl);
    font-weight: var(--ac-font-bold);
    color: var(--ac-text);
  }

  .ac-pricing__description {
    font-size: var(--ac-text-sm);
    color: var(--ac-text-muted);
  }

  .ac-pricing__price {
    display: flex;
    align-items: baseline;
    gap: var(--ac-spacing-1);
  }

  .ac-pricing__lower {
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-8);
  }

  .ac-pricing__currency {
    font-size: var(--ac-text-2xl);
    font-weight: var(--ac-font-bold);
    color: var(--ac-text);
  }

  .ac-pricing__amount {
    font-size: var(--ac-text-5xl);
    font-weight: var(--ac-font-extrabold);
    color: var(--ac-text);
    line-height: var(--ac-leading-none);
    transition: var(--ac-transition);
  }

  .ac-pricing__period {
    font-size: var(--ac-text-sm);
    color: var(--ac-text-muted);
  }

  .ac-pricing__cta {
    display: block;
    width: 100%;
    padding: var(--ac-spacing-3-5) var(--ac-spacing-6);
    font-size: var(--ac-text-sm);
    font-weight: var(--ac-font-semibold);
    text-align: center;
    text-decoration: none;
    border: 0.125rem solid var(--ac-border-color);
    border-radius: var(--ac-rounded-xl);
    color: var(--ac-text);
    transition: var(--ac-transition);
  }

  .ac-pricing__cta:hover {
    border-color: rgb(var(--ac-primary));
    color: rgb(var(--ac-primary));
  }

  .ac-pricing__cta--featured {
    background: var(--ac-gradient-primary);
    border-color: transparent;
    color: rgb(var(--ac-white));
  }

  .ac-pricing__cta--featured:hover {
    opacity: 0.9;
    color: rgb(var(--ac-white));
    box-shadow: 0 0.25rem 0.75rem rgba(var(--ac-primary), 0.4);
  }

  @media (max-width: 48rem) {
    .ac-pricing__card--featured {
      transform: none;
    }

    .ac-pricing__card--featured:hover {
      transform: translateY(-0.25rem);
    }
  }
</style>

---
import '../styles/globals.css'
import { siteConfig } from '../config/site.config'
import LandingSection from './LandingSection.astro'
import SectionHeader from './SectionHeader.astro'
import Icon from './Icon.astro'

const { integrations } = siteConfig
---

<LandingSection class="section ac-section-band--subtle" id="integrations">
  <div class="ac-integrations">
    <SectionHeader
      badge={integrations.badge}
      title={integrations.title}
      description={integrations.description}
      badgeSize="medium"
    />

    <div class="ac-integrations__main animate-fade-in-up">
    <!-- Category filter -->
    <div class="ac-integrations__filters" data-int-filters>
      <button class="ac-integrations__filter ac-integrations__filter--active" data-int-filter="all">
        All
      </button>
      {integrations.categories.map((cat) => (
        <button class="ac-integrations__filter" data-int-filter={cat.id}>
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Grid -->
    <div class="ac-integrations__grid" data-int-grid>
      {integrations.items.map((item) => (
        <div
          class="ac-integrations__card"
          data-int-category={item.category}
        >
          <div class="ac-integrations__card-icon">
            <Icon name={item.icon} size={28} />
          </div>
          <div class="ac-integrations__card-body">
            <h3 class="ac-integrations__card-name">{item.name}</h3>
            <p class="ac-integrations__card-desc">{item.description}</p>
          </div>
          <span class="ac-integrations__card-cat">{item.categoryLabel}</span>
        </div>
      ))}
    </div>

    {integrations.cta && (
      <div class="ac-integrations__footer">
        <p class="ac-integrations__footer-text">{integrations.cta.text}</p>
        <a href={integrations.cta.href} class="ac-integrations__footer-link">
          {integrations.cta.label}
          <Icon name="arrow-right" size={16} />
        </a>
      </div>
    )}
    </div>
  </div>
</LandingSection>

<style>
  .ac-integrations {
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-16);
    min-width: 0;
  }

  .ac-integrations__main {
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-12);
    min-width: 0;
  }

  /* Filters */
  .ac-integrations__filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--ac-spacing-2);
    justify-content: center;
  }

  .ac-integrations__filter {
    padding: var(--ac-spacing-2) var(--ac-spacing-5);
    border-radius: var(--ac-rounded-full);
    border: 0.0625rem solid var(--ac-border-color);
    background: var(--ac-card-bg);
    font-size: var(--ac-text-sm);
    font-weight: var(--ac-font-medium);
    color: var(--ac-text-muted);
    cursor: pointer;
    transition: var(--ac-transition);
    font-family: var(--ac-font-sans);
  }

  .ac-integrations__filter:hover {
    border-color: rgb(var(--ac-primary));
    color: rgb(var(--ac-primary));
  }

  .ac-integrations__filter--active {
    background: rgb(var(--ac-primary));
    border-color: rgb(var(--ac-primary));
    color: rgb(var(--ac-white));
  }

  .ac-integrations__filter--active:hover {
    color: rgb(var(--ac-white));
    opacity: 0.9;
  }

  /* Grid */
  .ac-integrations__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(16.25rem, 100%), 1fr));
    column-gap: var(--ac-spacing-6);
    row-gap: var(--ac-spacing-8);
    min-width: 0;
  }

  .ac-integrations__card {
    background: var(--ac-card-bg);
    border: 0.0625rem solid var(--ac-border-color);
    border-radius: var(--ac-rounded-2xl);
    padding: var(--ac-spacing-6);
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-4);
    transition: var(--ac-transition);
    box-shadow: var(--ac-shadow-sm);
    min-width: 0;
  }

  .ac-integrations__card:hover {
    transform: translateY(-0.1875rem);
    box-shadow: var(--ac-shadow-md);
    border-color: rgba(var(--ac-primary), 0.25);
  }

  .ac-integrations__card[data-hidden] {
    display: none;
  }

  .ac-integrations__card-icon {
    width: 3.25rem;
    height: 3.25rem;
    border-radius: var(--ac-rounded-xl);
    background: rgba(var(--ac-primary), 0.1);
    color: rgb(var(--ac-primary));
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ac-integrations__card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-1);
  }

  .ac-integrations__card-name {
    font-size: var(--ac-text-base);
    font-weight: var(--ac-font-bold);
    color: var(--ac-text);
  }

  .ac-integrations__card-desc {
    font-size: var(--ac-text-sm);
    color: var(--ac-text-muted);
    line-height: var(--ac-leading-relaxed);
  }

  .ac-integrations__card-cat {
    font-size: var(--ac-text-xs);
    font-weight: var(--ac-font-semibold);
    color: rgb(var(--ac-primary));
    background: rgba(var(--ac-primary), 0.08);
    padding: 0.1875rem var(--ac-spacing-3);
    border-radius: var(--ac-rounded-full);
    align-self: flex-start;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* Footer */
  .ac-integrations__footer {
    margin-top: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--ac-spacing-4);
    flex-wrap: wrap;
  }

  .ac-integrations__footer-text {
    font-size: var(--ac-text-base);
    color: var(--ac-text-muted);
  }

  .ac-integrations__footer-link {
    display: inline-flex;
    align-items: center;
    gap: var(--ac-spacing-2);
    font-size: var(--ac-text-sm);
    font-weight: var(--ac-font-semibold);
    color: rgb(var(--ac-primary));
    text-decoration: none;
    transition: gap 0.2s;
  }

  .ac-integrations__footer-link:hover {
    gap: var(--ac-spacing-3);
  }
</style>

<script>
  const filters = document.querySelectorAll('[data-int-filter]')
  const cards   = document.querySelectorAll('[data-int-category]') as NodeListOf<HTMLElement>

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      // Active state
      filters.forEach((b) => b.classList.remove('ac-integrations__filter--active'))
      btn.classList.add('ac-integrations__filter--active')

      const category = (btn as HTMLElement).dataset.intFilter ?? 'all'

      cards.forEach((card) => {
        if (category === 'all' || card.dataset.intCategory === category) {
          card.removeAttribute('data-hidden')
        } else {
          card.setAttribute('data-hidden', '')
        }
      })
    })
  })
</script>

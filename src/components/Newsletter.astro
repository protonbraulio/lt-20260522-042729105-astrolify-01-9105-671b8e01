---
import '../styles/globals.css'
import { siteConfig } from '../config/site.config'
import LandingSection from './LandingSection.astro'
import Icon from './Icon.astro'
import Input from './Input.astro'

const { newsletter, forms } = siteConfig
const rawNewsletterAction = forms?.newsletterAction?.trim() ?? ''
const newsletterNetlify = forms?.newsletterNetlify ?? false
const newsletterFormAction =
  rawNewsletterAction.length > 0 ? rawNewsletterAction : newsletterNetlify ? '/' : undefined
const newsletterDemoOnly = !rawNewsletterAction && !newsletterNetlify
---

<LandingSection class="section">
  <div class="ac-newsletter">
    <div class="ac-newsletter__card animate-fade-in-up">
      <div class="ac-newsletter__bg">
        <div class="ac-newsletter__blob ac-newsletter__blob--1"></div>
        <div class="ac-newsletter__blob ac-newsletter__blob--2"></div>
      </div>

      <div class="ac-newsletter__content">
        <div class="ac-newsletter__intro">
          <h2 class="ac-newsletter__title">{newsletter.title}</h2>
          <p class="ac-newsletter__description">{newsletter.description}</p>
        </div>

        <div class="ac-newsletter__signup">
          <form
            class="ac-newsletter__form"
            data-newsletter-form
            {...newsletterDemoOnly ? { 'data-demo-only': '' } : {}}
            action={newsletterFormAction}
            method={newsletterFormAction !== undefined || newsletterNetlify ? 'POST' : undefined}
            {...newsletterNetlify
              ? { 'data-netlify': 'true', name: 'newsletter' }
              : {}}
          >
            <Input
              class="ac-newsletter__email"
              type="email"
              name="email"
              placeholder={newsletter.placeholder}
              icon="mail"
              iconPosition="left"
              autocomplete="email"
              aria-label="Email"
              required
              variant="onAccent"
              wrapperClass="ac-newsletter__field"
            />
            <button type="submit" class="ac-newsletter__submit">
              <span class="ac-newsletter__submit-label">{newsletter.cta.label}</span>
              <Icon name="arrow_right" size={18} />
            </button>
          </form>

          <p class="ac-newsletter__note">
            Free 14-day trial. No credit card required.
          </p>
        </div>
      </div>
    </div>
  </div>
</LandingSection>

<style>
  .ac-newsletter__field {
    flex: 1;
    min-width: 0;
  }

  .ac-newsletter__card {
    position: relative;
    overflow: hidden;
    border-radius: var(--ac-rounded-3xl);
    padding: var(--ac-spacing-16) var(--ac-spacing-8);
    text-align: center;
    background: var(--ac-gradient-primary);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Animated blobs */
  .ac-newsletter__bg {
    position: absolute;
    inset: 0;
  }

  .ac-newsletter__blob {
    position: absolute;
    border-radius: 50%;
    opacity: 0.2;
    filter: blur(5rem);
  }

  .ac-newsletter__blob--1 {
    width: 25rem;
    height: 25rem;
    background: rgb(var(--ac-white));
    top: -6.25rem;
    right: -6.25rem;
  }

  .ac-newsletter__blob--2 {
    width: 18.75rem;
    height: 18.75rem;
    background: rgb(var(--ac-secondary));
    bottom: -6.25rem;
    left: -3.125rem;
  }

  .ac-newsletter__content {
    position: relative;
    z-index: 1;
    width: min(100%, 35rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ac-spacing-8);
  }

  .ac-newsletter__intro {
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-4);
    text-align: center;
  }

  .ac-newsletter__signup {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ac-spacing-4);
    width: 100%;
  }

  .ac-newsletter__title {
    font-size: var(--ac-text-4xl);
    font-weight: var(--ac-font-bold);
    color: rgb(var(--ac-white));
    line-height: var(--ac-leading-tight);
  }

  .ac-newsletter__description {
    font-size: var(--ac-text-lg);
    color: rgba(var(--ac-white), 0.8);
    line-height: var(--ac-leading-relaxed);
  }

  .ac-newsletter__form {
    display: flex;
    align-items: center;
    gap: var(--ac-spacing-3);
    max-width: 32.5rem;
    width: 100%;
  }

  .ac-newsletter__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--ac-spacing-2);
    height: var(--ac-spacing-12);
    padding-inline: var(--ac-spacing-6);
    font-size: var(--ac-text-sm);
    font-weight: var(--ac-font-semibold);
    color: rgb(var(--ac-primary));
    background: rgb(var(--ac-white));
    border: none;
    border-radius: var(--ac-rounded-xl);
    cursor: pointer;
    transition: var(--ac-transition);
    font-family: var(--ac-font-sans);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .ac-newsletter__submit:hover {
    transform: translateY(-0.125rem);
    box-shadow: 0 0.25rem 1rem rgba(0, 0, 0, 0.2);
  }

  .ac-newsletter__note {
    font-size: var(--ac-text-xs);
    color: rgba(var(--ac-white), 0.6);
    text-align: center;
  }

  @media (max-width: 48rem) {
    .ac-newsletter__card {
      padding: var(--ac-spacing-10) var(--ac-spacing-6);
    }

    .ac-newsletter__title {
      font-size: var(--ac-text-3xl);
    }

    .ac-newsletter__form {
      flex-direction: column;
      align-items: stretch;
    }

    .ac-newsletter__submit {
      justify-content: center;
      height: auto;
      padding-block: var(--ac-spacing-3-5);
    }
  }
</style>

<script>
  const form = document.querySelector('[data-newsletter-form]') as HTMLFormElement | null
  form?.addEventListener('submit', (e) => {
    if (!form.hasAttribute('data-demo-only')) return
    e.preventDefault()
    const btn = form.querySelector('.ac-newsletter__submit') as HTMLButtonElement | null
    const labelEl = form.querySelector('.ac-newsletter__submit-label') as HTMLElement | null
    if (btn && labelEl) {
      const prev = labelEl.textContent ?? ''
      labelEl.textContent = 'Subscribed!'
      btn.disabled = true
      window.setTimeout(() => {
        btn.disabled = false
        labelEl.textContent = prev
      }, 2400)
    }
  })
</script>

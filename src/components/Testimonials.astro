---
import '../styles/globals.css'
import { siteConfig } from '../config/site.config'
import LandingSection from './LandingSection.astro'
import SectionHeader from './SectionHeader.astro'
import Slider from './Slider.astro'
import Icon from './Icon.astro'

const { testimonials } = siteConfig
---

<LandingSection id="testimonials" class="section">
    <SectionHeader
      badge={testimonials.badge}
      title={testimonials.title}
      description={testimonials.description}
    />

    <div class="ac-testimonials__slider animate-fade-in-up">
      <Slider autoplay={true} interval={6000}>
        {testimonials.items.map((item) => (
          <div class:list={['ac-slider__slide', 'ac-testimonial']}>
            <div class="ac-testimonial__card">
              <div class="ac-testimonial__body">
                <div class="ac-testimonial__stars">
                  {[...Array(5)].map(() => (
                    <Icon name="star" size={18} class="ac-icon--testimonial-star" />
                  ))}
                </div>
                <blockquote class="ac-testimonial__text">
                  "{item.text}"
                </blockquote>
              </div>
              <div class="ac-testimonial__author">
                <img
                  src={item.avatar}
                  alt={item.name}
                  class="ac-testimonial__avatar"
                  width="48"
                  height="48"
                  loading="lazy"
                />
                <div>
                  <p class="ac-testimonial__name">{item.name}</p>
                  <p class="ac-testimonial__role">{item.role}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </Slider>
    </div>
</LandingSection>

<style>
  .ac-testimonials__slider {
    max-width: 43.75rem;
    width: 100%;
    align-self: center;
  }

  .ac-testimonial {
    padding: 0 var(--ac-spacing-4);
  }

  .ac-testimonial__card {
    background-color: var(--ac-card-bg);
    border: 0.0625rem solid var(--ac-card-border);
    border-radius: var(--ac-rounded-2xl);
    padding: var(--ac-spacing-10);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ac-spacing-8);
  }

  .ac-testimonial__body {
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-6);
    align-items: center;
  }

  .ac-testimonial__stars {
    display: flex;
    justify-content: center;
    gap: var(--ac-spacing-1);
    color: #facc15;
  }

  .ac-testimonial__text {
    font-size: var(--ac-text-lg);
    color: var(--ac-text);
    line-height: var(--ac-leading-relaxed);
    font-style: italic;
  }

  .ac-testimonial__author {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--ac-spacing-4);
  }

  .ac-testimonial__avatar {
    width: 3rem;
    height: 3rem;
    border-radius: var(--ac-rounded-full);
    object-fit: cover;
  }

  .ac-testimonial__name {
    font-size: var(--ac-text-sm);
    font-weight: var(--ac-font-semibold);
    color: var(--ac-text);
  }

  .ac-testimonial__role {
    font-size: var(--ac-text-xs);
    color: var(--ac-text-muted);
  }

  @media (max-width: 48rem) {
    .ac-testimonial__card {
      padding: var(--ac-spacing-6);
    }

    .ac-testimonial__text {
      font-size: var(--ac-text-md);
    }
  }
</style>

---
import '../styles/globals.css'
import Icon from './Icon.astro'
import { revealStaggerTokens } from '../utils/reveal'

export interface BlogPostCard {
  title: string
  excerpt: string
  category: string
  icon?: string
  date: string
  readTime: string
  href: string
  author: { name: string; avatar: string }
}

interface Props {
  post: BlogPostCard
  index: number
}

const { post, index } = Astro.props
const featured = index === 0
---

<article
  class:list={['ac-blog__card', featured && 'ac-blog__card--featured', ...revealStaggerTokens(index)]}
>
  <a href={post.href} class="ac-blog__card-link" aria-label={post.title}>
    <div class="ac-blog__card-cover">
      <div class="ac-blog__card-cover-inner">
        <Icon name={post.icon ?? 'note'} size={featured ? 48 : 36} />
      </div>
      <span class="ac-blog__card-category">{post.category}</span>
    </div>
  </a>

  <div class="ac-blog__card-body">
    <div class="ac-blog__card-meta">
      <time class="ac-blog__card-date">{post.date}</time>
      <span class="ac-blog__card-read">{post.readTime}</span>
    </div>

    <h3 class="ac-blog__card-title">
      <a href={post.href}>{post.title}</a>
    </h3>

    <p class="ac-blog__card-excerpt">{post.excerpt}</p>

    <div class="ac-blog__card-author">
      <img
        src={post.author.avatar}
        alt={post.author.name}
        class="ac-blog__author-avatar"
        width="32"
        height="32"
        loading="lazy"
      />
      <span class="ac-blog__author-name">{post.author.name}</span>
    </div>
  </div>
</article>

<style>
  .ac-blog__card {
    min-width: 0;
    background: var(--ac-card-bg);
    border: 0.0625rem solid var(--ac-border-color);
    border-radius: var(--ac-rounded-2xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: var(--ac-transition);
    box-shadow: var(--ac-shadow-sm);
  }

  .ac-blog__card:hover {
    transform: translateY(-0.25rem);
    box-shadow: var(--ac-shadow-lg);
    border-color: rgba(var(--ac-primary), 0.2);
  }

  .ac-blog__card-link {
    display: block;
    text-decoration: none;
  }

  .ac-blog__card-cover {
    position: relative;
    background: linear-gradient(
      135deg,
      rgba(var(--ac-primary), 0.12),
      rgba(var(--ac-primary), 0.04)
    );
    display: flex;
    align-items: center;
    justify-content: center;
    height: 11.25rem;
    overflow: hidden;
  }

  .ac-blog__card--featured .ac-blog__card-cover {
    height: 15rem;
  }

  .ac-blog__card-cover-inner {
    color: rgb(var(--ac-primary));
    opacity: 0.5;
    transition: all 0.3s;
  }

  .ac-blog__card:hover .ac-blog__card-cover-inner {
    opacity: 0.85;
    transform: scale(1.05);
  }

  .ac-blog__card-category {
    position: absolute;
    top: var(--ac-spacing-4);
    left: var(--ac-spacing-4);
    font-size: var(--ac-text-xs);
    font-weight: var(--ac-font-semibold);
    color: rgb(var(--ac-primary));
    background: rgba(var(--ac-primary), 0.12);
    padding: 0.1875rem var(--ac-spacing-3);
    border-radius: var(--ac-rounded-full);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border: 0.0625rem solid rgba(var(--ac-primary), 0.2);
  }

  .ac-blog__card-body {
    padding: var(--ac-spacing-6);
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-3);
  }

  .ac-blog__card-meta {
    display: flex;
    align-items: center;
    gap: var(--ac-spacing-3);
    font-size: var(--ac-text-xs);
    color: var(--ac-text-muted);
  }

  .ac-blog__card-date::after {
    content: '·';
    margin-left: var(--ac-spacing-3);
  }

  .ac-blog__card-title {
    font-size: var(--ac-text-lg);
    font-weight: var(--ac-font-bold);
    color: var(--ac-text);
    line-height: var(--ac-leading-tight);
  }

  .ac-blog__card--featured .ac-blog__card-title {
    font-size: var(--ac-text-2xl);
  }

  .ac-blog__card-title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }

  .ac-blog__card-title a:hover {
    color: rgb(var(--ac-primary));
  }

  .ac-blog__card-excerpt {
    font-size: var(--ac-text-sm);
    color: var(--ac-text-muted);
    line-height: var(--ac-leading-relaxed);
    flex: 1;
  }

  .ac-blog__card-author {
    display: flex;
    align-items: center;
    gap: var(--ac-spacing-3);
    margin-top: var(--ac-spacing-2);
    padding-top: var(--ac-spacing-4);
    border-top: 0.0625rem solid var(--ac-border-color);
  }

  .ac-blog__author-avatar {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    object-fit: cover;
  }

  .ac-blog__author-name {
    font-size: var(--ac-text-sm);
    font-weight: var(--ac-font-medium);
    color: var(--ac-text);
  }

  @media (min-width: 40rem) {
    .ac-blog__card--featured {
      grid-column: 1 / -1;
    }
  }
</style>

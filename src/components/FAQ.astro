---
import '../styles/globals.css'
import { siteConfig } from '../config/site.config'
import LandingSection from './LandingSection.astro'
import SectionHeader from './SectionHeader.astro'
import Accordion from './Accordion.astro'
import AccordionItem from './AccordionItem.astro'

const { faq } = siteConfig
---

<LandingSection id="faq" class="section">
  <SectionHeader badge={faq.badge} title={faq.title} description={faq.description} />

  <Accordion class="animate-fade-in-up">
    {
      faq.items.map((item) => (
        <AccordionItem name="faq" title={item.question} toggleStyle="chevron">
          <p>{item.answer}</p>
        </AccordionItem>
      ))
    }
  </Accordion>
</LandingSection>

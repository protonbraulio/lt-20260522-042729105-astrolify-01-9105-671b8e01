---
import '../styles/globals.css'
import { siteConfig } from '../config/site.config'
import LandingSection from './LandingSection.astro'
import SectionHeader from './SectionHeader.astro'
import TrustBadgeCard from './TrustBadgeCard.astro'
import Icon from './Icon.astro'

const { trust } = siteConfig
---

<LandingSection id="trust" class="section">
  <div class="ac-trust">
    <SectionHeader
      badge={trust.badge}
      title={trust.title}
      description={trust.description}
      badgeSize="medium"
    />

    <div class="ac-trust__grid">
      {trust.badges.map((badge, i) => <TrustBadgeCard badge={badge} index={i} />)}
    </div>

    {
      trust.certifications && (
        <div class="ac-trust__certs animate-fade-in-up">
          <p class="ac-trust__certs-label">Certified & Compliant with</p>
          <div class="ac-trust__certs-row">
            {trust.certifications.map((cert) => (
              <div class="ac-trust__cert-pill">
                <Icon name={cert.icon} size={16} />
                <span>{cert.name}</span>
              </div>
            ))}
          </div>
        </div>
      )
    }
  </div>
</LandingSection>

<style>
  .ac-trust {
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-16);
    min-width: 0;
  }

  .ac-trust__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    column-gap: var(--ac-spacing-6);
    row-gap: var(--ac-spacing-8);
    min-width: 0;
  }

  @media (min-width: 40rem) {
    .ac-trust__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .ac-trust__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .ac-trust__certs {
    margin-top: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ac-spacing-5);
  }

  .ac-trust__certs-label {
    font-size: var(--ac-text-sm);
    font-weight: var(--ac-font-semibold);
    color: var(--ac-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .ac-trust__certs-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--ac-spacing-3);
    justify-content: center;
  }

  .ac-trust__cert-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--ac-spacing-2);
    padding: var(--ac-spacing-2) var(--ac-spacing-4);
    border-radius: var(--ac-rounded-full);
    border: 0.0625rem solid var(--ac-border-color);
    background: var(--ac-card-bg);
    font-size: var(--ac-text-sm);
    font-weight: var(--ac-font-medium);
    color: var(--ac-text);
    box-shadow: var(--ac-shadow-sm);
  }
</style>

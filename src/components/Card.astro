---
import '../styles/globals.css'

interface Props {
  variant?: 'default' | 'bordered' | 'shadow' | 'ghost' | 'gradient-border'
  padding?: 'small' | 'medium' | 'large'
  hover?: boolean
  class?: string
}

const {
  variant = 'default',
  padding = 'medium',
  hover = true,
  class: className,
} = Astro.props

const variantClasses = {
  default: 'ac-card--default',
  bordered: 'ac-card--bordered',
  shadow: 'ac-card--shadow',
  ghost: 'ac-card--ghost',
  'gradient-border': 'ac-card--gradient-border',
}[variant]

const paddingClasses = {
  small: 'ac-card--pad-sm',
  medium: 'ac-card--pad-md',
  large: 'ac-card--pad-lg',
}[padding]
---

<div
  class:list={[
    'ac-card',
    variantClasses,
    paddingClasses,
    hover && 'ac-card--hover',
    className,
  ]}
>
  <slot />
</div>

<style>
  .ac-card {
    border-radius: var(--ac-rounded-2xl);
    transition: var(--ac-transition);
    position: relative;
    overflow: hidden;
  }

  .ac-card--pad-sm {
    padding: var(--ac-spacing-4);
  }

  .ac-card--pad-md {
    padding: var(--ac-spacing-8);
  }

  .ac-card--pad-lg {
    padding: var(--ac-spacing-12);
  }

  .ac-card--default {
    background-color: var(--ac-card-bg);
    border: 0.0625rem solid var(--ac-card-border);
  }

  .ac-card--bordered {
    background-color: transparent;
    border: 0.125rem solid var(--ac-card-border);
  }

  .ac-card--shadow {
    background-color: var(--ac-card-bg);
    box-shadow: var(--ac-shadow-lg);
  }

  .ac-card--ghost {
    background-color: var(--ac-bg-subtle);
  }

  .ac-card--gradient-border {
    background-color: var(--ac-card-bg);
    border: 0.125rem solid transparent;
    background-clip: padding-box;
    position: relative;
  }

  .ac-card--gradient-border::before {
    content: '';
    position: absolute;
    inset: -0.125rem;
    border-radius: inherit;
    background: var(--ac-gradient-primary);
    z-index: -1;
  }

  .ac-card--hover:hover {
    transform: translateY(-0.25rem);
    box-shadow: var(--ac-shadow-xl);
  }

  @media (max-width: 48rem) {
    .ac-card--pad-md {
      padding: var(--ac-spacing-6);
    }

    .ac-card--pad-lg {
      padding: var(--ac-spacing-8);
    }
  }
</style>

---
import '../styles/globals.css'
import Icon from './Icon.astro'
import { revealStaggerTokens } from '../utils/reveal'

interface BadgeItem {
  icon: string
  label: string
  description: string
}

interface Props {
  badge: BadgeItem
  index: number
}

const { badge, index } = Astro.props
---

<div class:list={['ac-trust__card', ...revealStaggerTokens(index)]}>
  <div class="ac-trust__icon">
    <Icon name={badge.icon} size={32} />
  </div>
  <h3 class="ac-trust__label">{badge.label}</h3>
  <p class="ac-trust__text">{badge.description}</p>
</div>

<style>
  .ac-trust__card {
    background: var(--ac-card-bg);
    border: 0.0625rem solid var(--ac-border-color);
    border-radius: var(--ac-rounded-2xl);
    padding: var(--ac-spacing-8) var(--ac-spacing-6);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--ac-spacing-3);
    transition: var(--ac-transition);
    box-shadow: var(--ac-shadow-sm);
    min-width: 0;
  }

  .ac-trust__card:hover {
    transform: translateY(-0.1875rem);
    box-shadow: var(--ac-shadow-md);
    border-color: rgba(var(--ac-primary), 0.2);
  }

  .ac-trust__icon {
    width: 4rem;
    height: 4rem;
    border-radius: var(--ac-rounded-2xl);
    background: rgba(var(--ac-primary), 0.1);
    color: rgb(var(--ac-primary));
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ac-trust__label {
    font-size: var(--ac-text-base);
    font-weight: var(--ac-font-bold);
    color: var(--ac-text);
  }

  .ac-trust__text {
    font-size: var(--ac-text-sm);
    color: var(--ac-text-muted);
    line-height: var(--ac-leading-relaxed);
  }
</style>

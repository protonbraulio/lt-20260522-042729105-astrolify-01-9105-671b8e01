---
import '../styles/globals.css'
import { siteConfig } from '../config/site.config'
import LandingSection from './LandingSection.astro'
import SectionHeader from './SectionHeader.astro'
import Tab from './Tab.astro'
import TabItem from './TabItem.astro'
import Icon from './Icon.astro'

const { featureTabs } = siteConfig
---

<LandingSection class="section ac-section-band--subtle" id="feature-tabs">
  <div class="ac-feature-tabs">
    <SectionHeader
      badge={featureTabs.badge}
      title={featureTabs.title}
      description={featureTabs.description}
      badgeSize="medium"
    />

    <Tab class="animate-fade-in-up" tabs={featureTabs.tabs.map((t, i) => ({ label: t.label, active: i === 0 }))}>
      {featureTabs.tabs.map((tab, i) => (
        <TabItem active={i === 0}>
          <div class="ac-feature-tabs__panel">
            <div class="ac-feature-tabs__features">
              {tab.features.map((feature) => (
                <div class="ac-feature-tabs__feature">
                  <div class="ac-feature-tabs__feature-icon">
                    <Icon name={feature.icon} size={22} />
                  </div>
                  <div class="ac-feature-tabs__feature-body">
                    <h3 class="ac-feature-tabs__feature-title">{feature.title}</h3>
                    <p class="ac-feature-tabs__feature-desc">{feature.description}</p>
                  </div>
                </div>
              ))}
            </div>
            <div class="ac-feature-tabs__visual">
              <div class="ac-feature-tabs__visual-inner">
                <div class="ac-feature-tabs__visual-badge">
                  <Icon name={tab.icon} size={28} />
                </div>
                <h4 class="ac-feature-tabs__visual-title">{tab.label}</h4>
                <p class="ac-feature-tabs__visual-text">{tab.summary}</p>
                {tab.cta && (
                  <a href={tab.cta.href} class="ac-feature-tabs__cta">
                    {tab.cta.label}
                    <Icon name="arrow-right" size={16} />
                  </a>
                )}
              </div>
            </div>
          </div>
        </TabItem>
      ))}
    </Tab>
  </div>
</LandingSection>

<style>
  .ac-feature-tabs {
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-16);
    min-width: 0;
  }

  /* Tab panel layout */
  .ac-feature-tabs__panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    column-gap: var(--ac-spacing-12);
    row-gap: var(--ac-spacing-10);
    align-items: start;
    padding-top: var(--ac-spacing-8);
    min-width: 0;
  }

  /* Features list */
  .ac-feature-tabs__features {
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-8);
    min-width: 0;
  }

  .ac-feature-tabs__feature {
    display: flex;
    gap: var(--ac-spacing-4);
    align-items: flex-start;
  }

  .ac-feature-tabs__feature-icon {
    flex-shrink: 0;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--ac-rounded-xl);
    background: rgba(var(--ac-primary), 0.1);
    color: rgb(var(--ac-primary));
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ac-feature-tabs__feature-body {
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-2);
    min-width: 0;
  }

  .ac-feature-tabs__feature-title {
    font-size: var(--ac-text-base);
    font-weight: var(--ac-font-semibold);
    color: var(--ac-text);
  }

  .ac-feature-tabs__feature-desc {
    font-size: var(--ac-text-sm);
    color: var(--ac-text-muted);
    line-height: var(--ac-leading-relaxed);
  }

  /* Visual card */
  .ac-feature-tabs__visual {
    border-radius: var(--ac-rounded-2xl);
    background: linear-gradient(135deg,
      rgba(var(--ac-primary), 0.08) 0%,
      rgba(var(--ac-primary), 0.02) 100%
    );
    border: 0.0625rem solid rgba(var(--ac-primary), 0.15);
    padding: var(--ac-spacing-10);
    min-height: 20rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ac-feature-tabs__visual-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--ac-spacing-4);
  }

  .ac-feature-tabs__visual-badge {
    width: 4.5rem;
    height: 4.5rem;
    border-radius: var(--ac-rounded-2xl);
    background: var(--ac-gradient-primary);
    color: rgb(var(--ac-white));
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0.5rem 1.5rem rgba(var(--ac-primary), 0.3);
  }

  .ac-feature-tabs__visual-title {
    font-size: var(--ac-text-2xl);
    font-weight: var(--ac-font-bold);
    color: var(--ac-text);
  }

  .ac-feature-tabs__visual-text {
    font-size: var(--ac-text-base);
    color: var(--ac-text-muted);
    line-height: var(--ac-leading-relaxed);
    max-width: 17.5rem;
  }

  .ac-feature-tabs__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--ac-spacing-2);
    font-size: var(--ac-text-sm);
    font-weight: var(--ac-font-semibold);
    color: rgb(var(--ac-primary));
    text-decoration: none;
    margin-top: var(--ac-spacing-2);
    transition: gap 0.2s;
  }

  .ac-feature-tabs__cta:hover {
    gap: var(--ac-spacing-3);
  }

  @media (max-width: 48rem) {
    .ac-feature-tabs__panel {
      grid-template-columns: 1fr;
    }

    .ac-feature-tabs__visual {
      min-height: 13.75rem;
    }
  }
</style>

---
import '../styles/globals.css'
import Icon from './Icon.astro'

interface Props {
  items: string[]
  iconSize?: number
}

const { items, iconSize = 16 } = Astro.props
---

<ul class="ac-pricing__features">
  {
    items.map((feature) => (
      <li class="ac-pricing__feature">
        <Icon name="check" size={iconSize} class="ac-icon--pricing-check" />
        <span>{feature}</span>
      </li>
    ))
  }
</ul>

<style>
  .ac-pricing__features {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-3);
  }

  .ac-pricing__feature {
    display: flex;
    align-items: center;
    gap: var(--ac-spacing-3);
    font-size: var(--ac-text-sm);
    color: var(--ac-text-muted);
  }
</style>

---
import '../styles/globals.css'
import { siteConfig } from '../config/site.config'
import LandingSection from './LandingSection.astro'
import SectionHeader from './SectionHeader.astro'
import BlogCard from './BlogCard.astro'
import Icon from './Icon.astro'

const { blog } = siteConfig
---

<LandingSection id="blog" class="section ac-section-band--subtle">
  <div class="ac-blog">
    <SectionHeader
      badge={blog.badge}
      title={blog.title}
      description={blog.description}
      badgeSize="medium"
    />

    <div class="ac-blog__grid">
      {blog.posts.map((post, index) => <BlogCard post={post} index={index} />)}
    </div>

    {
      blog.cta && (
        <div class="ac-blog__footer">
          <a href={blog.cta.href} class="ac-blog__cta">
            {blog.cta.label}
            <Icon name="arrow-right" size={16} />
          </a>
        </div>
      )
    }
  </div>
</LandingSection>

<style>
  .ac-blog {
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-16);
  }

  .ac-blog__grid {
    display: grid;
    grid-template-columns: 1fr;
    column-gap: var(--ac-spacing-6);
    row-gap: var(--ac-spacing-8);
  }

  @media (min-width: 40rem) {
    .ac-blog__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .ac-blog__footer {
    display: flex;
    justify-content: center;
  }

  .ac-blog__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--ac-spacing-2);
    font-size: var(--ac-text-sm);
    font-weight: var(--ac-font-semibold);
    color: rgb(var(--ac-primary));
    text-decoration: none;
    padding: var(--ac-spacing-3) var(--ac-spacing-6);
    border: 0.125rem solid rgb(var(--ac-primary));
    border-radius: var(--ac-rounded-xl);
    transition: var(--ac-transition);
  }

  .ac-blog__cta:hover {
    background: rgb(var(--ac-primary));
    color: rgb(var(--ac-white));
    transform: translateY(-0.0625rem);
    box-shadow: 0 0.25rem 1rem rgba(var(--ac-primary), 0.3);
  }
</style>

---
import Layout from '../layouts/Layout.astro'
import { siteConfig } from '../config/site.config'

const title = `Privacy Policy — ${siteConfig.brand.name}`
const description = `How ${siteConfig.brand.name} collects, uses, and protects your personal information.`

const updated = 'April 7, 2026'
---

<Layout title={title} description={description}>
  <article class="ac-legal">
    <header class="ac-legal__header">
      <h1 class="ac-legal__title">Privacy Policy</h1>
      <p class="ac-legal__meta">
        Last updated: <time datetime="2026-04-07">{updated}</time>
      </p>
    </header>

    <div class="ac-legal__body">
      <p class="ac-legal__notice">
        This page is <strong>sample copy</strong> for a starter template. Replace it with your real policy
        and have it reviewed by qualified legal counsel before publishing.
      </p>

      <section class="ac-legal__section" aria-labelledby="legal-intro">
        <h2 id="legal-intro">Introduction</h2>
        <p>
          {siteConfig.brand.name} (&quot;we&quot;, &quot;us&quot;, or &quot;our&quot;) respects your privacy. This policy
          describes how we handle information when you use our website and services (the
          &quot;Services&quot;).
        </p>
      </section>

      <section class="ac-legal__section" aria-labelledby="legal-collect">
        <h2 id="legal-collect">Information we collect</h2>
        <p>We may collect:</p>
        <ul>
          <li>
            <strong>Account data</strong> — such as name, email, and organization when you register or contact us.
          </li>
          <li>
            <strong>Usage data</strong> — such as pages visited, approximate location (derived from IP), device type, and
            timestamps.
          </li>
          <li>
            <strong>Technical data</strong> — such as browser type, cookies, and similar technologies as described below.
          </li>
        </ul>
      </section>

      <section class="ac-legal__section" aria-labelledby="legal-use">
        <h2 id="legal-use">How we use information</h2>
        <p>We use collected information to:</p>
        <ul>
          <li>Provide, operate, and improve the Services;</li>
          <li>Communicate with you about updates, security, and support;</li>
          <li>Analyze usage in aggregated or de-identified form;</li>
          <li>Comply with law and protect rights, safety, and security.</li>
        </ul>
      </section>

      <section class="ac-legal__section" aria-labelledby="legal-cookies">
        <h2 id="legal-cookies">Cookies and similar technologies</h2>
        <p>
          We and our partners may use cookies, local storage, and similar technologies for essential operation,
          preferences (such as theme), analytics, and marketing where permitted. You can control cookies through
          your browser settings.
        </p>
      </section>

      <section class="ac-legal__section" aria-labelledby="legal-sharing">
        <h2 id="legal-sharing">Sharing and subprocessors</h2>
        <p>
          We may share information with service providers who assist us (e.g. hosting, analytics, email delivery),
          subject to contracts that limit use to providing services on our behalf. We may also disclose
          information if required by law or to protect users and the public.
        </p>
      </section>

      <section class="ac-legal__section" aria-labelledby="legal-rights">
        <h2 id="legal-rights">Your rights and choices</h2>
        <p>
          Depending on where you live, you may have rights to access, correct, delete, or export personal data,
          or to object to certain processing. Contact us to exercise these rights. You may also unsubscribe from
          marketing emails using the link in those messages.
        </p>
      </section>

      <section class="ac-legal__section" aria-labelledby="legal-retention">
        <h2 id="legal-retention">Retention</h2>
        <p>
          We retain information only as long as necessary for the purposes above, unless a longer period is
          required by law.
        </p>
      </section>

      <section class="ac-legal__section" aria-labelledby="legal-changes">
        <h2 id="legal-changes">Changes to this policy</h2>
        <p>
          We may update this policy from time to time. We will post the new version on this page and adjust the
          &quot;Last updated&quot; date.
        </p>
      </section>

      <section class="ac-legal__section" aria-labelledby="legal-contact">
        <h2 id="legal-contact">Contact</h2>
        <p>
          Questions about this policy: use the contact options on our website or reach your account
          representative.
        </p>
      </section>
    </div>
  </article>
</Layout>

<style>
  .ac-legal {
    max-width: 42rem;
    margin: 0 auto;
    padding: var(--ac-spacing-12) var(--ac-container-padding) var(--ac-spacing-24);
  }

  .ac-legal__header {
    margin-bottom: var(--ac-spacing-10);
    padding-bottom: var(--ac-spacing-8);
    border-bottom: var(--ac-border) solid var(--ac-border-color);
  }

  .ac-legal__title {
    font-size: var(--ac-text-4xl);
    font-weight: var(--ac-font-bold);
    line-height: var(--ac-leading-tight);
    color: var(--ac-text);
    margin: 0 0 var(--ac-spacing-3);
  }

  .ac-legal__meta {
    margin: 0;
    font-size: var(--ac-text-sm);
    color: var(--ac-text-muted);
  }

  .ac-legal__body {
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-10);
    font-size: var(--ac-text-md);
    line-height: var(--ac-leading-relaxed);
    color: var(--ac-text);
  }

  .ac-legal__notice {
    margin: 0;
    padding: var(--ac-spacing-4) var(--ac-spacing-5);
    border-radius: var(--ac-rounded-xl);
    background: var(--ac-bg-subtle);
    border: var(--ac-border) solid var(--ac-border-color);
    font-size: var(--ac-text-sm);
    color: var(--ac-text-muted);
  }

  .ac-legal__section h2 {
    font-size: var(--ac-text-xl);
    font-weight: var(--ac-font-bold);
    color: var(--ac-text);
    margin: 0 0 var(--ac-spacing-4);
    line-height: var(--ac-leading-tight);
  }

  .ac-legal__section p {
    margin: 0 0 var(--ac-spacing-4);
  }

  .ac-legal__section p:last-child {
    margin-bottom: 0;
  }

  .ac-legal__section ul {
    margin: 0 0 var(--ac-spacing-4);
    padding-left: var(--ac-spacing-6);
    display: flex;
    flex-direction: column;
    gap: var(--ac-spacing-3);
    color: var(--ac-text-muted);
  }

  .ac-legal__section li strong {
    color: var(--ac-text);
    font-weight: var(--ac-font-semibold);
  }

  .ac-legal__section:last-child p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 48rem) {
    .ac-legal__title {
      font-size: var(--ac-text-3xl);
    }
  }
</style>
